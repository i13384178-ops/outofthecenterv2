rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // App uses collection "camp", document id "state" (see src/camp/storage.ts).
    // Deploy: Firebase Console → Firestore → Rules → paste → Publish
    // Or: firebase deploy --only firestore:rules (with firebase.json pointing here)
    match /camp/state {
      allow read, write: if true;
    }
  }
}
